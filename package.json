{
  "name": "@julianoczkowski/agentwiki",
  "version": "0.1.11",
  "description": "Deterministic codebase wiki engine that recruits the coding agent you already have (Cursor CLI, Claude Code) to write the prose. No API keys, no LLM calls of its own.",
  "license": "MIT",
  "author": "Julian Oczkowski",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "agentwiki": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "wiki",
    "documentation",
    "docs",
    "cli",
    "cursor",
    "claude-code",
    "agents",
    "ai",
    "codebase",
    "knowledge-base",
    "deepwiki",
    "tree-sitter-free",
    "offline"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julianoczkowski/agentwiki.git"
  },
  "bugs": {
    "url": "https://github.com/julianoczkowski/agentwiki/issues"
  },
  "homepage": "https://github.com/julianoczkowski/agentwiki#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.tsx",
    "postbuild": "chmod +x dist/cli.js",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
